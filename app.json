{
  "expo": {
    "name": "Ankaa Design",
    "slug": "ankaa-design",
    "version": "1.0",
    "orientation": "default",
    "icon": "./assets/icon-1024.png",
    "scheme": "ankaadesign",
    "userInterfaceStyle": "automatic",
    "jsEngine": "hermes",
    "splash": {
      "image": "./assets/icon-1024.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ankaadesign.management",
      "buildNumber": "8",
      "jsEngine": "hermes",
      "requireFullScreen": true,
      "config": {
        "usesNonExemptEncryption": false
      },
      "associatedDomains": [
        "applinks:ankaadesign.com.br",
        "applinks:www.ankaadesign.com.br"
      ],
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "LSApplicationQueriesSchemes": [
          "whatsapp"
        ],
        "NSFaceIDUsageDescription": "Necessário para autenticação biométrica na confirmação de entrega de EPI",
        "NSLocationWhenInUseUsageDescription": "Necessário para registrar a localização no momento da assinatura de entrega de EPI",
        "NSCameraUsageDescription": "Necessário para tirar fotos de check-in e check-out"
      }
    },
    "android": {
      "package": "com.ankaadesign.management",
      "googleServicesFile": "./android/app/google-services.json",
      "jsEngine": "hermes",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon-foreground.png",
        "backgroundColor": "#FFFFFF"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/app/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/task/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/order/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/item/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/service-order/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/producao/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/estoque/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/departamento-pessoal/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/administracao/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/pintura/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/financeiro/"
            },
            {
              "scheme": "https",
              "host": "ankaadesign.com.br",
              "pathPrefix": "/pessoal/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/app/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/task/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/order/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/item/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/service-order/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/producao/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/estoque/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/departamento-pessoal/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/administracao/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/pintura/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/financeiro/"
            },
            {
              "scheme": "https",
              "host": "www.ankaadesign.com.br",
              "pathPrefix": "/pessoal/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#15803d",
          "mode": "production"
        }
      ],
      [
        "expo-screen-orientation",
        {
          "initialOrientation": "DEFAULT"
        }
      ],
      "expo-background-fetch",
      "expo-task-manager",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Necessário para autenticação biométrica na confirmação de entrega de EPI"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Necessário para registrar a localização no momento da assinatura de entrega de EPI"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Necessário para tirar fotos de check-in e check-out"
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Necessário para tirar fotos de check-in e check-out",
          "enableMicrophonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "newArchEnabled": true,
    "runtimeVersion": "7",
    "updates": {
      "enabled": true,
      "url": "https://api.ankaadesign.com.br/updates/manifest",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "f8f06f52-853f-4ab6-a783-181208687fa7"
      },
      "apiUrl": "https://api.ankaadesign.com.br",
      "fallbackApiUrl": "http://192.168.10.180:3030"
    }
  }
